# Copy to .env and fill in. Loaded automatically by public/index.php when present.
DB_HOST=127.0.0.1
DB_PORT=3306
DB_DATABASE=mini_blog
DB_USERNAME=root
DB_PASSWORD=Mysql#123

# Mailtrap — Email Testing (SMTP credentials from your Mailtrap inbox)
MAILTRAP_HOST=sandbox.smtp.mailtrap.io
MAILTRAP_PORT=2525
MAILTRAP_USER=
MAILTRAP_PASSWORD=
# tls (default) | ssl | none
MAILTRAP_ENCRYPTION=tls

# Where contact form messages are addressed (your inbox)
CONTACT_EMAIL=ahr.web.pro@gmail.com

# Optional display name for the From header (SMTP From must be accepted by Mailtrap)
# CONTACT_FROM_NAME=Mini Blog
# CONTACT_FROM_EMAIL=
